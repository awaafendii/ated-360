// ============================================================
// ATED-360 — Schéma de base de données (Prisma + PostgreSQL)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Énumérations ----------

enum Role {
  PRODUCTEUR
  PARTENAIRE
}

enum Zone {
  BEYLA
  BOFFA
  BOKE
  CONAKRY
  COYAH
  DABOLA
  DALABA
  DINGUIRAYE
  DUBREKA
  FARANAH
  FORECARIAH
  FRIA
  GAOUAL
  GUECKEDOU
  KANKAN
  KAMSAR
  KEROUANE
  KINDIA
  KISSIDOUGOU
  KOUNDARA
  KOUROUSSA
  KOUBIA
  LABE
  LELOUMA
  LOLA
  MACENTA
  MALI
  MANDIANA
  MAMOU
  NZEREKORE
  PITA
  SANGAREDI
  SIGUIRI
  TELIMELE
  TOUGUE
  YOMOU
}

enum FarmType {
  AVICOLE
  AGRICOLE
  MIXTE
}

enum RecordType {
  ALIMENTATION
  VACCINATION
  TRAITEMENT
  RENDEMENT
}

enum AlertPriority {
  URGENT
  NORMAL
  INFO
}

enum AlertKind {
  VACCIN
  CLIMAT
  TRAITEMENT
}

enum DroneStatus {
  DEMANDE_ENVOYEE // demande créée par le producteur
  PLANIFIE        // créneau confirmé par un pilote
  REALISE         // survol effectué, images en traitement
  RAPPORT_PRET    // rapport agronomique disponible
  ANNULE
}

enum DronePack {
  SURVOL   // cartographie RGB simple
  SANTE    // diagnostic NDVI + rapport
  COMPLET  // NDVI + thermique + comptage
}

enum ProofType {
  PHOTO
  VIDEO
  DOCUMENT
}

// ---------- Utilisateur & authentification ----------

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  phone        String?   @unique
  passwordHash String
  fullName     String
  dateOfBirth  DateTime?
  role         Role      @default(PRODUCTEUR)
  zone         Zone?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  producer Producer?

  @@map("users")
}

// ---------- Profil producteur (ferme) ----------

model Producer {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  zone      Zone
  farmType  FarmType @default(MIXTE)
  fieldLocation String? // localisation précise du champ/parcelle (au-delà de la ville)
  cultures      String[] @default([]) // cultures pratiquées, déclarées par le producteur (multi-choix)
  // Effectifs / surfaces déclarés (servent au tableau de bord et au score)
  poultryCount Int   @default(0)
  hectares     Float @default(0)

  // ---- CV & présentation de la structure (crédibilité auprès des partenaires) ----
  cvUrl          String? // lien vers le CV téléversé (Cloudinary)
  startYear      Int?    // année de démarrage des activités
  investedAmount String? // montants investis dans les projets (texte libre : devise variable)
  youthEmployed  Int?    // nombre de jeunes employés
  womenEmployed  Int?    // nombre de femmes employées
  annualRevenue  String? // chiffre d'affaires annuel (texte libre)
  legalStatus    String? // "Formel" | "Informel"
  challenges     String? // échecs rencontrés
  achievements   String? // réussites
  outlook        String? // perspectives / espoirs

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  records  Record[]
  alerts   Alert[]
  missions DroneMission[]
  scores   ScoreSnapshot[]
  proofs   Proof[]

  @@map("producers")
}

// ---------- Preuves (photos, vidéos, documents administratifs) ----------
// Justifient les cultures/activités déclarées et le statut formel/informel
// de la structure, pour sécuriser la décision des partenaires.

model Proof {
  id         String    @id @default(uuid())
  producerId String
  producer   Producer  @relation(fields: [producerId], references: [id], onDelete: Cascade)

  type       ProofType
  label      String?
  url        String

  createdAt  DateTime  @default(now())

  @@index([producerId])
  @@map("proofs")
}

// ---------- Registre digital ----------

model Record {
  id         String     @id @default(uuid())
  producerId String
  producer   Producer   @relation(fields: [producerId], references: [id], onDelete: Cascade)

  type       RecordType
  farmType   FarmType   // AVICOLE ou AGRICOLE
  detail     String
  quantity   String?    // texte libre : "320 sujets", "45 kg", "0,5 ha"
  zone       Zone

  // Détails spécifiques stockés en JSON (espèce/effectif/vaccin OU culture/sol/rendement...)
  // Flexible : évite des dizaines de colonnes nullables.
  details    Json?

  occurredAt DateTime   @default(now())
  createdAt  DateTime   @default(now())

  @@index([producerId, type])
  @@index([producerId, occurredAt])
  @@map("records")
}

// ---------- Alertes ----------

model Alert {
  id         String        @id @default(uuid())
  producerId String
  producer   Producer      @relation(fields: [producerId], references: [id], onDelete: Cascade)

  priority   AlertPriority
  kind       AlertKind
  title      String
  description String
  dueAt      DateTime?     // échéance (rappel vaccinal, traitement programmé)
  resolved   Boolean       @default(false)

  createdAt  DateTime      @default(now())

  @@index([producerId, resolved])
  @@map("alerts")
}

// ---------- Drones : missions & rapports ----------

model DroneMission {
  id         String      @id @default(uuid())
  producerId String
  producer   Producer    @relation(fields: [producerId], references: [id], onDelete: Cascade)

  pack       DronePack
  parcelle   String
  culture    String
  hectares   Float?
  zone       Zone
  scheduledFor DateTime?
  note       String?
  status     DroneStatus @default(DEMANDE_ENVOYEE)

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  report DroneReport?

  @@index([producerId, status])
  @@map("drone_missions")
}

model DroneReport {
  id         String       @id @default(uuid())
  missionId  String       @unique
  mission    DroneMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  ndvi          Float   // indice moyen 0..1
  healthScore   Int     // 0..100
  waterStress   String  // "Faible" | "Modéré" | "Élevé"
  observation   String  // constat agronomique
  recommendation String
  mapUrl        String? // URL d'une carte NDVI générée (optionnel)

  createdAt  DateTime @default(now())

  @@map("drone_reports")
}

// ---------- Historique de score ----------
// Un instantané est enregistré à chaque recalcul (traçabilité pour les partenaires).

model ScoreSnapshot {
  id         String   @id @default(uuid())
  producerId String
  producer   Producer @relation(fields: [producerId], references: [id], onDelete: Cascade)

  global     Int      // 0..100
  // Détail des critères en JSON : { "biosecurite": 70, "vaccination": 88, ... }
  breakdown  Json
  farmType   FarmType // volet évalué

  createdAt  DateTime @default(now())

  @@index([producerId, createdAt])
  @@map("score_snapshots")
}
