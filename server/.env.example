# ============================================================
# ATED-360 — Variables d'environnement
# Copiez ce fichier en `.env` et renseignez les valeurs réelles.
# ============================================================

# --- Serveur ---
NODE_ENV=development
PORT=4000

# URL du frontend autorisée pour CORS (React).
# En production, mettez l'URL réelle ; plusieurs valeurs séparées par des virgules.
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# --- Base de données PostgreSQL ---
# Format : postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://ated:ated_password@localhost:5432/ated360?schema=public"

# --- Authentification JWT ---
# IMPORTANT : générez une vraie clé en production, p.ex.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=remplacez_moi_par_une_cle_longue_et_aleatoire
JWT_EXPIRES_IN=7d

# --- Sécurité ---
BCRYPT_SALT_ROUNDS=12

# --- Stockage de fichiers (CV, preuves) — compte gratuit sur cloudinary.com ---
# Sans ces 3 valeurs, l'upload de CV/preuves est désactivé (le reste de l'app fonctionne).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
